{
  "andon": {
    "PreInvocation": [
      {
        "type": "command",
        "command": "/usr/bin/python3 /PATH/TO/andon/hooks/generic_status_hook.py antigravity PreInvocation",
        "timeout": 5
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 /PATH/TO/andon/hooks/generic_status_hook.py antigravity PostToolUse",
            "timeout": 5
          }
        ]
      }
    ],
    "PostInvocation": [
      {
        "type": "command",
        "command": "/usr/bin/python3 /PATH/TO/andon/hooks/generic_status_hook.py antigravity PostInvocation",
        "timeout": 5
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "/usr/bin/python3 /PATH/TO/andon/hooks/generic_status_hook.py antigravity Stop",
        "timeout": 5
      }
    ]
  }
}
